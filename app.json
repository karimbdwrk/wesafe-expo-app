{
  "expo": {
    "name": "WeSafeApp",
    "slug": "wesafeapp",
    "owner": "wesafe",
    "platforms": [
      "ios",
      "android"
    ],
    "extra": {
      "SUPABASE_URL": "https://hzvbylhdptwgblpdondm.supabase.co",
      "SUPABASE_API_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imh6dmJ5bGhkcHR3Z2JscGRvbmRtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDU0NTA5MjksImV4cCI6MjA2MTAyNjkyOX0.UdtpnbES2Ul7TDFBcHIpGnVxFxqQYmGt-WVtMHgewk4",
      "SUPERADMIN_ID": "c5f72d6f-7ab4-4e19-8b3b-12714740efad",
      "eas": {
        "projectId": "9c9684c7-a279-43ca-a263-987be5e4c6d9"
      },
      "router": {}
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "my-app",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera."
      },
      "bundleIdentifier": "com.wesafe.wesafeapp"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.wesafe.wesafeapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-dev-client",
      "react-native-vision-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "cameraPermission": "The app accesses your camera to let you take pictures with your friends."
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.wesafe.wesafeapp",
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}